# EditorConfig — https://editorconfig.org
# Applies to all editors that support it (VS Code, JetBrains, Vim, etc.)
root = true

# ── Defaults ────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ── Python ──────────────────────────────────────────────────────────────────
# 4 spaces — enforced by ruff in pyproject.toml
[*.py]
indent_size = 4
max_line_length = 100

# ── Shell scripts ────────────────────────────────────────────────────────────
[*.sh]
indent_size = 4

# ── Dockerfiles ──────────────────────────────────────────────────────────────
[Dockerfile]
indent_size = 4

# ── YAML ─────────────────────────────────────────────────────────────────────
# 2 spaces is the universal YAML convention
[*.{yml,yaml}]
indent_size = 2

# ── TOML ─────────────────────────────────────────────────────────────────────
[*.toml]
indent_size = 2

# ── JSON ─────────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ── Markdown ─────────────────────────────────────────────────────────────────
# Trailing whitespace is significant in Markdown (two spaces = <br>),
# so we leave it alone.
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# ── Makefile ─────────────────────────────────────────────────────────────────
# Tabs are required — make will reject spaces.
[Makefile]
indent_style = tab
