# =============================================================================
# protonmail-local-ai — environment configuration
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   then edit .env with your values
# =============================================================================

# -----------------------------------------------------------------------------
# ProtonBridge
# -----------------------------------------------------------------------------
# Obtained after first-run interactive login:
#   make first-run → bridge --cli → login → info
BRIDGE_USER=your@proton.me

# Bridge version — bump this to update to a new release
# Check: https://github.com/ProtonMail/proton-bridge/releases
BRIDGE_VERSION=v3.24.2

# -----------------------------------------------------------------------------
# mbsync
# -----------------------------------------------------------------------------
# How often to sync in seconds (60 = every minute)
SYNC_INTERVAL=60

# Bridge TLS cert pin rotation. On first boot mbsync saves the SHA-256
# fingerprint of Bridge's TLS cert to a persistent volume and refuses to
# sync on subsequent boots if the fingerprint changes. When Bridge's cert
# is deliberately rotated (e.g. a Bridge version upgrade), set this to
# true for a single restart — mbsync will overwrite the pin with the new
# fingerprint — then set it back to false. Leaving it true permanently
# disables pin enforcement.
BRIDGE_CERT_PIN_ROTATE=false

# -----------------------------------------------------------------------------
# Embedder (OpenAI-compatible /v1/embeddings via the openai SDK)
# -----------------------------------------------------------------------------
# Indexer and mcp-server both call the embedder via the official ``openai``
# SDK with a custom ``base_url``. ``EMBED_MODE`` selects the wire shape;
# only ``openai`` is active today. ``none`` disables the embed layer in
# mcp-server (keyword-only retrieval) and is rejected by the indexer
# at startup (the indexer cannot ingest mail without embeddings).
#
# Examples (uncomment one and adjust to match your install):
# EMBED_BASE_URL=http://host.docker.internal:8001/v1
# EMBED_MODEL=mlx-community/Qwen3-Embedding-8B-mxfp8
#
# EMBED_BASE_URL=https://api.deepinfra.com/v1/openai
# EMBED_MODEL=Qwen/Qwen3-Embedding-8B
#
# EMBED_BASE_URL=https://openrouter.ai/api/v1
# EMBED_MODEL=qwen/qwen3-embedding-8b
#
# IMPORTANT: indexer and mcp-server must point at the same provider +
# model so query vectors are comparable to indexed vectors. The schema
# reserves a fixed 4096-dim vector — keep ``EMBED_MODEL`` pointed at a
# 4096-dim model (Qwen3-Embedding-8B variants) or a schema migration
# is required.
EMBED_MODE=openai
EMBED_BASE_URL=
EMBED_MODEL=

# Bearer credential for the embedder. Leave the secret file empty when
# pointing at an unauthenticated host server; write provider keys to
# ``.secrets/embed_api_key.txt`` when the endpoint authenticates.

# Per-call deadline for query-time embed in mcp-server (seconds).
# Default 60 s is generous headroom over Qwen3-Embedding-8B's
# sub-second steady-state. Cold-start in the indexer is governed
# separately by EMBED_WARMUP_TIMEOUT_SECS.
# EMBED_TIMEOUT_SECS=60

# Inputs packed into a single /v1/embeddings POST. Larger batches
# amortize per-request overhead — meaningful for remote providers,
# marginal for loopback host endpoints. The provider's per-request
# input cap is the upper bound.
EMBED_BATCH_SIZE=64

# How many messages the initial-scan drainer accumulates before
# issuing a single batched embed call. The two-phase batched indexer
# commits thread membership per message (Phase 1, durable; seed
# vector picks one of three sources in priority order: mean of the
# thread's existing chunk vectors when the thread is already indexed
# with content; the prior threads_vec row when the thread is
# chunkless but has a non-zero vector — covers subject-fallback
# threads from earlier blank-body messages; placeholder zero only
# for genuinely new threads) for up to this many messages, then
# issues one embed_batch covering every new chunk's text across the
# whole batch (Phase 2b), then commits chunks/vectors per message
# (Phase 2c). This collapses ~25k single-message HTTP round-trips
# into ~500 multi-message ones against a cloud embedder.
# Steady-state (watchdog) ingestion now runs through the same batched
# path with a smaller default batch size — see
# INDEXER_STEADY_STATE_BATCH_SIZE below.
INITIAL_INDEX_BATCH_SIZE=50

# Steady-state (post-initial-scan) batch size for the main-loop drain.
# A burst from an mbsync sync still gets one bulk embed call instead of
# one HTTP round-trip per message — decisive against any cloud
# embedder. Smaller than INITIAL_INDEX_BATCH_SIZE because steady-state
# typically sees 1-3 messages per pass; the value is the upper bound,
# not a target. Set lower if interleaving with the reconciler / WAL
# checkpoint matters more than burst throughput.
INDEXER_STEADY_STATE_BATCH_SIZE=8

# How often (seconds) the main loop runs PRAGMA wal_checkpoint(TRUNCATE).
# The single shared SQLite connection used by the indexer keeps a WAL
# read snapshot live for the duration of the process; without an
# explicit truncate-checkpoint the WAL file grows monotonically. 10
# minutes keeps the file size bounded without churning IO.
INDEXER_WAL_CHECKPOINT_INTERVAL_SECS=600

# How often (seconds) the main loop re-runs the recovery sweep that
# re-enqueues messages stuck on chunkless zero-vector threads. The
# periodic sweep handles retryable shapes — a queue row still in
# 'queued' state, or one that was cleaned up out-of-band — so a
# transient process death heals on its own once the underlying
# cause clears. Dead-lettered rows are NOT auto-recovered by the
# periodic sweep (or the startup sweep); ``initial_index`` and the
# recovery sweep both respect the durable queue's bounded-retry
# contract. To resurrect a dead-lettered file, an operator confirms
# the underlying cause is fixed and either re-enqueues the row
# manually or runs a one-off rescue tool.
INDEXER_RECOVERY_SWEEP_INTERVAL_SECS=1800

# -----------------------------------------------------------------------------
# Reranker (post-RRF cross-encoder stage in mcp-server's hybrid search)
# -----------------------------------------------------------------------------
# RERANK_MODE selects the provider:
#
#   - cohere: Cohere's hosted rerank API via the official ``cohere`` SDK.
#     Set RERANK_MODEL (e.g. ``rerank-v4.0-pro``) and write the API key to
#     ``.secrets/rerank_api_key.txt``. Leave RERANK_BASE_URL empty to use
#     the SDK default (``https://api.cohere.com``); set it only when
#     pointing at a proxy / gateway / region override.
#   - none: rerank disabled. Hybrid search returns RRF-fused order
#     directly. This is the default.
RERANK_MODE=none
RERANK_BASE_URL=
RERANK_MODEL=

# Number of RRF candidates fed into the reranker. Higher gives the
# cross-encoder more recall to work with at the cost of more model
# forward passes per query (one yes/no scoring pass per candidate).
RERANK_CANDIDATES=20

# Default top-K returned when the caller doesn't specify a limit.
# This is a *default*, not a hard cap — callers like
# ``extract_from_emails(limit=20)`` override it via the rerank
# protocol's ``top_n`` argument so the rerank stage doesn't silently
# undercut a larger requested result set.
RERANK_TOP_N=10

# Per-call deadline (seconds) for the Cohere rerank API. Default 60s
# is shorter than the SDK's 300s default so a stalled rerank call
# doesn't pin a hybrid_search worker thread for five minutes; rerank
# failures fall back to RRF order so a tighter ceiling is safe.
RERANK_TIMEOUT_SECS=60

# Override the warmup POST timeout when bringing the indexer up
# against a cold embedder. First-time model loads on host-side
# providers can take several minutes; the default 600s absorbs that
# with margin. Lower it on a warm cache for faster startup-failure
# detection.
# EMBED_WARMUP_TIMEOUT_SECS=600

# Acknowledge the destructive v13→v14 migration. The v14 schema
# resizes the embedding vector tables from the prior 768-dim model
# to 4096-dim (Qwen3-Embedding-8B) and clears message_chunks /
# message_chunks_fts / indexed_files / indexing_jobs so the next
# scan re-embeds. On a populated v13 install that means hours of
# indexing work get reset, so the indexer refuses by default. Set
# this to ``true`` AFTER confirming you want to proceed.
# INDEXER_MIGRATION_V14_FORCE=false

# -----------------------------------------------------------------------------
# Inference (mcp-server intelligence tools)
# -----------------------------------------------------------------------------
# INFERENCE_MODE selects the wire protocol/SDK:
#
#   - anthropic (default): Anthropic Messages API via the official
#     ``anthropic`` SDK. Leave INFERENCE_BASE_URL empty to hit the SDK
#     default (api.anthropic.com); set it only for compatible gateways.
#     Retrieved email chunks are sent to the configured provider — review
#     the privacy implications in README.md before enabling.
#   - openai: OpenAI-compatible chat completions via the official
#     ``openai`` SDK. The endpoint can be remote (any compliant provider)
#     or a host-side server you install yourself (LM Studio, vLLM,
#     mlx_lm.server). Containers reach the host via OrbStack's
#     ``host.docker.internal``. INFERENCE_BASE_URL is required.
#   - none: intelligence tools (ask_mailbox, summarize_thread,
#     extract_from_emails) are not registered. Search and retrieval
#     still work.
#
# There is no inter-mode fallback: choosing a mode without its required
# vars (INFERENCE_BASE_URL where required, INFERENCE_MODEL,
# INFERENCE_API_KEY) is a startup error. Write the API key to
# ``.secrets/inference_api_key.txt`` (mode 600); never put credentials here.
INFERENCE_MODE=anthropic

# Endpoint URL. Required for INFERENCE_MODE=openai. Optional for
# INFERENCE_MODE=anthropic — leave empty to use the SDK default
# (https://api.anthropic.com). Examples:
#   http://host.docker.internal:8002/v1   (local OpenAI-compatible server)
#   https://api.deepinfra.com/v1/openai   (DeepInfra)
#   https://openrouter.ai/api/v1          (OpenRouter)
INFERENCE_BASE_URL=

# Model id served at INFERENCE_BASE_URL. Examples:
#   claude-sonnet-4-6                 (anthropic mode)
#   mlx-community/Qwen3-32B-4bit      (openai mode against mlx_lm.server)
#   gpt-4o-mini                       (openai mode against api.openai.com)
INFERENCE_MODEL=claude-sonnet-4-6

# Per-call deadline for inference completions (seconds). Default 300 s
# catches truly stuck calls without false-positiving on slow-but-
# progressing inference (Qwen3 in thinking mode can run ~1-2 minutes
# for a long answer; reasoning-heavy Anthropic prompts can stretch).
# Lower it for fast remote providers; raise it on slow networks.
# INFERENCE_TIMEOUT_SECS=300

# Output token cap. Required by the Anthropic Messages API; the OpenAI
# Chat Completions API accepts it too and most compatible servers
# (vLLM, mlx_lm.server, LM Studio, DeepInfra) honor it. Default 1024
# fits brief summaries + action-item extraction; raise to 4096+ for
# detailed summaries on long threads or schemas with many fields.
# INFERENCE_MAX_TOKENS=1024

# -----------------------------------------------------------------------------
# Indexer — deletion reconciliation (opt-in)
# -----------------------------------------------------------------------------
# mbsync runs Sync Pull + Expunge None, so remote deletions on ProtonMail are
# marked locally by adding the Maildir "T" flag rather than removing the file.
# The indexer can optionally tombstone those files and, after a grace window,
# reap the corresponding rows from the local SQLite index. Default: disabled.
#
# Enable tombstoning + reaping. Disabled by default so existing behavior
# (local index is append-only) is preserved for upgrades.
INDEXER_DELETION_ENABLED=false

# Days to keep a tombstoned message in the index before the reaper removes it.
# During the grace window the message stays searchable; if mbsync un-sets the
# T flag on a subsequent pull, the tombstone is cleared with no data loss.
INDEXER_DELETION_GRACE_DAYS=7

# How often (seconds) the indexer re-runs sweep + reap while the container is
# up. Minimum 60.
INDEXER_DELETION_SWEEP_INTERVAL_SECS=3600

# Mass-delete brake: fraction of total indexed messages the reaper may touch
# in a single pass. Protects against Bridge vault rebuilds, folder renames, or
# auth glitches that mark a huge batch as T-deleted. Override with
# INDEXER_DELETION_FORCE=true for intentional bulk cleanups.
INDEXER_DELETION_MAX_BATCH_PCT=0.05
INDEXER_DELETION_FORCE=false

# When true, also unlink the Maildir .eml file after a reap. Default false
# keeps the file on disk so mbsync --full can re-pull if Proton still has it.
# Note: the indexer mounts Maildir read-only by default, so unlink calls will
# log a warning and no-op unless you also switch the mount to read-write.
INDEXER_UNLINK_ON_REAP=false

# -----------------------------------------------------------------------------
# Indexer — durable retry queue
# -----------------------------------------------------------------------------
# The indexer records every file to be indexed in an indexing_jobs table
# and drains it via a worker loop. Transient failures (embedder unreachable,
# SQLite lock) exponentially back off; persistent failures transition
# to status='dead' and stop being retried until re-enqueued.

# Max retries before a row becomes dead-lettered. Dead rows stay in the
# table so operators can inspect last_stage / last_error; they do not
# keep retrying until something re-enqueues the same filepath (for
# instance an mbsync re-delivery).
INDEXER_MAX_ATTEMPTS=5

# Base backoff in seconds. Each attempt multiplies by 2^(attempts-1)
# and is capped at 6 hours, so a transient outage doesn't hide work
# for longer than an ops shift.
INDEXER_RETRY_BASE_SECONDS=30

# -----------------------------------------------------------------------------
# Indexer — per-message chunker
# -----------------------------------------------------------------------------
# The indexer slices each message body into paragraph-packed chunks
# before embedding. Each chunk is stored, FTS-indexed, and embedded
# individually; the parent thread vector is the mean of its chunk
# vectors. Chunks also flow through the chunk-vector retrieval lane
# in mcp-server's hybrid search so a query matching one passage lifts
# its parent thread into ranking. See ``src/chunker.py`` for the
# algorithm.

# Preferred chunk size in tokens. The chunker closes a chunk once it
# reaches this budget while still on a paragraph boundary. Token-sized
# rather than char-sized so the budgets are comparable across embed
# models with different context-window assumptions. Default 1000 is
# sized for Qwen3-Embedding-8B's 32K-token context.
INDEXER_CHUNK_TARGET_TOKENS=1000

# Hard ceiling per chunk. Paragraphs over this size are split at
# sentence, word, and finally tokenizer-boundary granularity.
# Default 1500 fits well within Qwen3-Embedding-8B's context.
INDEXER_CHUNK_MAX_TOKENS=1500

# Overlap tail carried from one chunk into the next, sized so that
# question-answering across a chunk boundary still finds matching
# evidence. Default scaled with the larger chunk size. Set to 0 to
# disable overlap.
INDEXER_CHUNK_OVERLAP_TOKENS=150

# Per-message parse byte cap. Files larger than this are dead-lettered
# without being read into memory; sized below the indexer container's
# ``mem_limit`` so a single oversized message cannot OOM the indexer.
# ``0`` disables the cap; raise this on environments with larger
# inbound mail limits if a legitimate message hits the dead-letter
# path with "exceeds INDEXER_PARSE_MAX_BYTES".
INDEXER_PARSE_MAX_BYTES=50000000

# -----------------------------------------------------------------------------
# Indexer — attachment extraction
# -----------------------------------------------------------------------------
# The indexer extracts text from message attachments (PDF, DOCX, XLSX,
# HTML, TXT/CSV, images via OCR), chunks it, and feeds it through the
# same retrieval lane as message bodies. Filenames + MIME types are
# also indexed for "find that PDF" queries. Extraction work is deduped
# per content hash so a forwarded PDF is OCR'd / parsed at most once
# regardless of how many emails carry it.

# Master switch. Disable to skip attachment processing entirely (e.g.
# during a high-volume initial sync where attachments can wait).
INDEXER_ATTACHMENT_EXTRACTION_ENABLED=true

# Tesseract / Poppler-based OCR for image attachments and the
# scanned-PDF fallback. Disable to keep the indexer CPU lighter but
# lose retrieval over scanned receipts, screenshots, and image-only
# PDFs.
INDEXER_OCR_ENABLED=true

# Skip attachments larger than this many bytes. Bounds CPU and memory
# under a single email with a huge backup zip. Default 10 MB skips
# almost no real attachments while preventing pathological cases.
INDEXER_ATTACHMENT_MAX_BYTES=10000000

# Cap pages OCR'd per PDF — a 500-page scanned book attachment would
# otherwise monopolise CPU. Pages beyond the cap are silently skipped;
# operator can lift the cap and re-run extraction for affected
# attachments by clearing their attachment_extractions row.
INDEXER_OCR_MAX_PAGES=20

# Per-page Tesseract timeout. A crafted high-noise image (still under
# INDEXER_ATTACHMENT_MAX_BYTES) can keep Tesseract busy for minutes per
# page; combined with INDEXER_OCR_MAX_PAGES that pins the worker for
# tens of minutes per PDF. Set to 0 to disable the timeout (not
# recommended). Failure surfaces as a STATUS_FAILED extraction row.
INDEXER_OCR_TIMEOUT_SECONDS=60

# Cap pages walked by the digital pypdf path. The OCR cap above only
# bounds the rendered-image fallback; a 5 MB text-only PDF can carry
# thousands of pages and even at ms-per-page would stall the queue.
# Set to 0 to disable the cap.
INDEXER_PDF_MAX_DIGITAL_PAGES=500

# Cap on the number of characters of extracted text persisted per
# attachment. Bounds the size of ``attachment_extractions.extracted_text``
# rows so a multi-hundred-page OCR'd PDF cannot store tens of MB of text
# in SQLite. Default 2,000,000 ~ 500 pages of dense text. Set to 0 to
# disable the cap. Lifting the cap requires clearing the affected
# attachment_extractions rows so the truncated text is re-extracted.
INDEXER_ATTACHMENT_MAX_EXTRACTED_CHARS=2000000

# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------
# Port exposed to localhost for Claude Desktop
# Do not expose this port publicly
MCP_PORT=3000

# MCP transport: "sse" for Claude Desktop compatibility, "streamable-http"
# for clients that require Streamable HTTP, or "dual" to serve both /sse
# and /mcp on the same localhost-bound port.
MCP_TRANSPORT=sse

# Safe default: do not register mail-changing tools in the MCP server.
# Set to false only after you intentionally enable and verify a cert-pinned
# write path. This flag alone does not enable live Bridge actions.
MCP_READ_ONLY=true
