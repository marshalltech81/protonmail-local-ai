# =============================================================================
# protonmail-local-ai — environment configuration
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   then edit .env with your values
# =============================================================================

# -----------------------------------------------------------------------------
# ProtonBridge
# -----------------------------------------------------------------------------
# Obtained after first-run interactive login:
#   make first-run → bridge --cli → login → info
BRIDGE_USER=your@proton.me

# Bridge version — bump this to update to a new release
# Check: https://github.com/ProtonMail/proton-bridge/releases
BRIDGE_VERSION=v3.24.1

# -----------------------------------------------------------------------------
# mbsync
# -----------------------------------------------------------------------------
# How often to sync in seconds (60 = every minute)
SYNC_INTERVAL=60

# Bridge TLS cert pin rotation. On first boot mbsync saves the SHA-256
# fingerprint of Bridge's TLS cert to a persistent volume and refuses to
# sync on subsequent boots if the fingerprint changes. When Bridge's cert
# is deliberately rotated (e.g. a Bridge version upgrade), set this to
# true for a single restart — mbsync will overwrite the pin with the new
# fingerprint — then set it back to false. Leaving it true permanently
# disables pin enforcement.
BRIDGE_CERT_PIN_ROTATE=false

# -----------------------------------------------------------------------------
# Ollama
# -----------------------------------------------------------------------------
# Embedding model to use for vector search
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM model for local Q&A and agentic tasks
OLLAMA_LLM_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Indexer — deletion reconciliation (opt-in)
# -----------------------------------------------------------------------------
# mbsync runs Sync Pull + Expunge None, so remote deletions on ProtonMail are
# marked locally by adding the Maildir "T" flag rather than removing the file.
# The indexer can optionally tombstone those files and, after a grace window,
# reap the corresponding rows from the local SQLite index. Default: disabled.
#
# Enable tombstoning + reaping. Disabled by default so existing behavior
# (local index is append-only) is preserved for upgrades.
INDEXER_DELETION_ENABLED=false

# Days to keep a tombstoned message in the index before the reaper removes it.
# During the grace window the message stays searchable; if mbsync un-sets the
# T flag on a subsequent pull, the tombstone is cleared with no data loss.
INDEXER_DELETION_GRACE_DAYS=7

# How often (seconds) the indexer re-runs sweep + reap while the container is
# up. Minimum 60.
INDEXER_DELETION_SWEEP_INTERVAL_SECS=3600

# Mass-delete brake: fraction of total indexed messages the reaper may touch
# in a single pass. Protects against Bridge vault rebuilds, folder renames, or
# auth glitches that mark a huge batch as T-deleted. Override with
# INDEXER_DELETION_FORCE=true for intentional bulk cleanups.
INDEXER_DELETION_MAX_BATCH_PCT=0.05
INDEXER_DELETION_FORCE=false

# When true, also unlink the Maildir .eml file after a reap. Default false
# keeps the file on disk so mbsync --full can re-pull if Proton still has it.
# Note: the indexer mounts Maildir read-only by default, so unlink calls will
# log a warning and no-op unless you also switch the mount to read-write.
INDEXER_UNLINK_ON_REAP=false

# -----------------------------------------------------------------------------
# Indexer — durable retry queue
# -----------------------------------------------------------------------------
# The indexer records every file to be indexed in an indexing_jobs table
# and drains it via a worker loop. Transient failures (Ollama down,
# SQLite lock) exponentially back off; persistent failures transition
# to status='dead' and stop being retried until re-enqueued.

# Max retries before a row becomes dead-lettered. Dead rows stay in the
# table so operators can inspect last_stage / last_error; they do not
# keep retrying until something re-enqueues the same filepath (for
# instance an mbsync re-delivery).
INDEXER_MAX_ATTEMPTS=5

# Base backoff in seconds. Each attempt multiplies by 2^(attempts-1)
# and is capped at 6 hours, so a transient outage doesn't hide work
# for longer than an ops shift.
INDEXER_RETRY_BASE_SECONDS=30

# -----------------------------------------------------------------------------
# Indexer — per-message chunker
# -----------------------------------------------------------------------------
# The indexer slices each message body into paragraph-packed chunks
# before embedding. Each chunk is stored, FTS-indexed, and embedded
# individually; the parent thread vector is the mean of its chunk
# vectors. Chunks also flow through the chunk-vector retrieval lane
# in mcp-server's hybrid search so a query matching one passage lifts
# its parent thread into ranking. See ``src/chunker.py`` for the
# algorithm.

# Preferred chunk size in tokens. The chunker closes a chunk once it
# reaches this budget while still on a paragraph boundary. Token-sized
# rather than char-sized so the budgets are comparable across embed
# models with different context-window assumptions.
INDEXER_CHUNK_TARGET_TOKENS=350

# Hard ceiling per chunk. Paragraphs over this size are split at
# sentence boundaries, then word boundaries as a last resort. Should
# stay well under the embedding model's context window — for
# nomic-embed-text (8192) the default 500 leaves headroom for header
# fields the chunker doesn't tokenize.
INDEXER_CHUNK_MAX_TOKENS=500

# Overlap tail carried from one chunk into the next, sized so that
# question-answering across a chunk boundary still finds matching
# evidence. Set to 0 to disable overlap (saves a few percent of embed
# cost; usually not worth it).
INDEXER_CHUNK_OVERLAP_TOKENS=60

# -----------------------------------------------------------------------------
# Indexer — attachment extraction
# -----------------------------------------------------------------------------
# The indexer extracts text from message attachments (PDF, DOCX, XLSX,
# HTML, TXT/CSV, images via OCR), chunks it, and feeds it through the
# same retrieval lane as message bodies. Filenames + MIME types are
# also indexed for "find that PDF" queries. Extraction work is deduped
# per content hash so a forwarded PDF is OCR'd / parsed at most once
# regardless of how many emails carry it.

# Master switch. Disable to skip attachment processing entirely (e.g.
# during a high-volume initial sync where attachments can wait).
INDEXER_ATTACHMENT_EXTRACTION_ENABLED=true

# Tesseract / Poppler-based OCR for image attachments and the
# scanned-PDF fallback. Disable to keep the indexer CPU lighter but
# lose retrieval over scanned receipts, screenshots, and image-only
# PDFs.
INDEXER_OCR_ENABLED=true

# Skip attachments larger than this many bytes. Bounds CPU and memory
# under a single email with a huge backup zip. Default 10 MB skips
# almost no real attachments while preventing pathological cases.
INDEXER_ATTACHMENT_MAX_BYTES=10000000

# Cap pages OCR'd per PDF — a 500-page scanned book attachment would
# otherwise monopolise CPU. Pages beyond the cap are silently skipped;
# operator can lift the cap and re-run extraction for affected
# attachments by clearing their attachment_extractions row.
INDEXER_OCR_MAX_PAGES=20

# Per-page Tesseract timeout. A crafted high-noise image (still under
# INDEXER_ATTACHMENT_MAX_BYTES) can keep Tesseract busy for minutes per
# page; combined with INDEXER_OCR_MAX_PAGES that pins the worker for
# tens of minutes per PDF. Set to 0 to disable the timeout (not
# recommended). Failure surfaces as a STATUS_FAILED extraction row.
INDEXER_OCR_TIMEOUT_SECONDS=60

# Cap pages walked by the digital pypdf path. The OCR cap above only
# bounds the rendered-image fallback; a 5 MB text-only PDF can carry
# thousands of pages and even at ms-per-page would stall the queue.
# Set to 0 to disable the cap.
INDEXER_PDF_MAX_DIGITAL_PAGES=500

# Cap on the number of characters of extracted text persisted per
# attachment. Bounds the size of ``attachment_extractions.extracted_text``
# rows so a multi-hundred-page OCR'd PDF cannot store tens of MB of text
# in SQLite. Default 2,000,000 ~ 500 pages of dense text. Set to 0 to
# disable the cap. Lifting the cap requires clearing the affected
# attachment_extractions rows so the truncated text is re-extracted.
INDEXER_ATTACHMENT_MAX_EXTRACTED_CHARS=2000000

# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------
# Port exposed to localhost for Claude Desktop
# Do not expose this port publicly
MCP_PORT=3000

# MCP transport: "sse" for Claude Desktop compatibility, "streamable-http"
# for clients such as Open WebUI, or "dual" to serve both /sse and /mcp on
# the same localhost-bound port.
MCP_TRANSPORT=sse

# Safe default: do not register mail-changing tools in the MCP server.
# Set to false only after you intentionally enable and verify a cert-pinned
# write path. This flag alone does not enable live Bridge actions.
MCP_READ_ONLY=true

# -----------------------------------------------------------------------------
# Optional Open WebUI
# -----------------------------------------------------------------------------
# Start with: make open-webui-up
# The UI shares the existing ollama container and connects to the MCP server
# over Streamable HTTP at http://mcp-server:3000/mcp. Set MCP_TRANSPORT=dual
# or MCP_TRANSPORT=streamable-http before starting it.
# Image is pinned by digest in docker-compose.open-webui.yml; override
# this to roll forward only after verifying the new digest yourself.
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.9.0@sha256:eb874c0530209dd5ca21a4d0a7cc42e69f2ee85f0e7b90ae94659cd415c27c6d
OPEN_WEBUI_PORT=8080
OPEN_WEBUI_NAME=ProtonMail Local AI
# Defaults to ${OLLAMA_LLM_MODEL} when unset; override here only if you
# want Open WebUI to default to a different model than the rest of the
# stack uses.
OPEN_WEBUI_DEFAULT_MODEL=
# Memory ceiling for the open-webui container. 1g covers ordinary use;
# raise if you load very large tokenizers / RAG indexes.
OPEN_WEBUI_MEM_LIMIT=1g

# Open WebUI requires a session key for stable sessions and encrypted stored
# settings. This is a Docker Compose secret, not an env var.
# `make open-webui-up` auto-generates .secrets/open_webui_secret_key.txt via
# openssl on first run; delete the file and re-run the target to rotate.

# Default-deny signup. To create the first-run admin account, set this
# to true once (e.g. `OPEN_WEBUI_ENABLE_SIGNUP=true make open-webui-up`),
# create the account in the UI, then flip back to false and restart
# Open WebUI. Default-allow is unsafe on a shared workstation: Open
# WebUI grants admin to whoever signs up first, and the loopback bind
# alone does not exclude other local users from racing you.
OPEN_WEBUI_ENABLE_SIGNUP=false

# LLM mode: "local" (Ollama) or "cloud" (Claude API)
# Applies to the deployed MCP server instance
LLM_MODE=local

# Claude model for cloud mode
CLAUDE_MODEL=claude-sonnet-4-6

# Claude API key — only required if LLM_MODE=cloud
# Write the key to .secrets/anthropic_api_key.txt (never put it here).
# For local-only mode, leave the file empty:
#   printf '' > .secrets/anthropic_api_key.txt && chmod 600 .secrets/anthropic_api_key.txt
# For cloud mode:
#   printf '%s' 'sk-ant-...' > .secrets/anthropic_api_key.txt && chmod 600 .secrets/anthropic_api_key.txt
