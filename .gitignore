# Secrets — never commit these
.env
.secrets/
*.pem
*.key

# Docker volumes if mounted locally
data/
maildir/
# ``indexer/src/data/`` is bundled source data (e.g. the nomic-embed-text
# tokenizer.json) — exempt it from the broad ``data/`` ignore above so
# the data files ship in the indexer image build context.
!indexer/src/data/
!indexer/src/data/**

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Claude Code
.claude/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Build artifacts
*.db
*.sqlite

# Logs
*.log
logs/

# Eval queries grounded in a real mailbox — must never be committed.
# The ``.example`` companions are tracked as schema/templates.
mcp-server/tests/eval/queries.json
mcp-server/tests/eval/eval-queries.md
